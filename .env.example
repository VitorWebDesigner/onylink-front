# ───────────────────────── Backend (AUTO) ─────────────────────────
# A URL é resolvida sozinha em src/lib/config.ts — não precisa mexer pra buildar:
#   • Expo Go / dev → back LOCAL no IP da sua máquina :4444 (precisa estar rodando)
#   • Build de loja → servidor de produção
#
# Override manual (força uma URL específica):
# EXPO_PUBLIC_API_URL=http://SEU-BACKEND:4444

# Mesmo TRANSPORT_SECRET do backend (envelope payload-in-JWT)
EXPO_PUBLIC_TRANSPORT_SECRET=change-me-transport

# 1 = tudo mock (offline, sem backend)
EXPO_PUBLIC_MOCK=0
